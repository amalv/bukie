{
  "name": "bukie",
  "version": "0.30.3",
  "private": true,
  "scripts": {
    "build": "bun run db:migrate:pg && bun run db:seed:pg && next build",
    "build:ci": "next build",
    "build-storybook": "storybook build",
    "dev": "next dev",
    "db:generate": "bunx drizzle-kit generate",
    "db:generate:pg": "bunx drizzle-kit generate --config ./drizzle.config.pg.ts",
    "db:migrate": "bunx drizzle-kit migrate",
    "db:migrate:pg": "bun ./scripts/db/migrate.pg.ts",
    "db:init:pg": "bun ./scripts/db/init.pg.ts",
    "db:seed": "bunx tsx ./scripts/db/seed.ts",
    "db:seed:pg": "bunx tsx ./scripts/db/seed.pg.ts",
    "db:reset": "bun ./scripts/db/reset.ts",
    "db:reseed": "bun run db:reset && bun run db:migrate && bun run db:seed",
    "lint": "bunx @biomejs/biome check --no-errors-on-unmatched .",
    "lint:fix": "bunx @biomejs/biome check --write --no-errors-on-unmatched .",
    "release": "semantic-release",
    "start": "bun run db:migrate:pg || true && next start",
    "start:ci": "next start",
    "storybook": "storybook dev -p 6006",
    "test": "bunx vitest --config vitest.config.unit.ts --run",
    "test:coverage": "bunx vitest --config vitest.config.unit.ts --coverage --run",
    "test:playwright": "bunx playwright test",
    "test:storybook": "bunx vitest --config vitest.config.storybook.ts",
    "images:optimize": "bun ./scripts/optimize-images.ts --webp --maxWidth 450 --quality 80",
    "db:list": "bunx tsx ./scripts/db/list-books.ts",
    "db:import": "bunx tsx ./scripts/db/import-batch.ts",
    "db:purge:genre": "bunx tsx ./scripts/db/purge-genre.ts",
    "db:import:sci-fi": "bun run db:import -- --input=./artifacts/catalog/sci-fi.ts --category=\"Science Fiction\" --batch-size=100 --mode=upsert",
    "db:import:fantasy": "bun run db:import -- --input=./artifacts/catalog/fantasy.ts --category=\"Fantasy\" --batch-size=100 --mode=upsert",
    "db:import:mystery-thriller": "bun run db:import -- --input=./artifacts/catalog/mystery-thriller.ts --category=\"Mystery & Thriller\" --batch-size=100 --mode=upsert",
    "db:import:non-fiction": "bun run db:import -- --input=./artifacts/catalog/non-fiction.ts --category=\"Non-Fiction\" --batch-size=100 --mode=upsert",
    "db:import:classics": "bun run db:import -- --input=./artifacts/catalog/classics.ts --category=\"Classics\" --batch-size=100 --mode=upsert",
    "db:import:catalog": "bun run db:import:sci-fi && bun run db:import:fantasy && bun run db:import:mystery-thriller && bun run db:import:non-fiction && bun run db:import:classics",
    "db:sync:sci-fi": "bun run db:purge:genre -- --genre=\"Science Fiction\" && bun run db:import:sci-fi && bun run covers:fetch -- --limit=100 --concurrency=3",
    "db:report": "bunx tsx ./scripts/db/report-summary.ts",
    "db:sync:covers": "bunx tsx ./scripts/db/sync-covers.ts",
    "covers:fetch": "bunx tsx ./scripts/covers/fetch-covers.ts",
    "covers:prune": "bunx tsx ./scripts/covers/prune-unused.ts",
    "covers:suggest": "bunx tsx ./scripts/covers/suggest-mappings.ts",
    "covers:rename:id": "bunx tsx ./scripts/covers/rename-to-id.ts",
    "covers:canonicalize": "bunx tsx ./scripts/covers/canonicalize.ts"
  },
  "dependencies": {
    "better-sqlite3": "^12.8.0",
    "drizzle-orm": "^0.45.1",
    "lucide-react": "^0.577.0",
    "next": "^16.2.0-canary.99",
    "postgres": "^3.4.8",
    "react": "^19.2.4",
    "react-dom": "^19.2.4"
  },
  "devDependencies": {
    "@biomejs/biome": "^2.4.7",
    "@chromatic-com/storybook": "^5.0.1",
    "@commitlint/cli": "^20.5.0",
    "@commitlint/config-conventional": "^20.5.0",
    "@playwright/test": "^1.58.2",
    "@semantic-release/changelog": "^6.0.3",
    "@semantic-release/git": "^10.0.1",
    "@semantic-release/github": "^12.0.6",
    "@semantic-release/npm": "^13.1.5",
    "@storybook/addon-a11y": "^10.2.19",
    "@storybook/addon-docs": "^10.2.19",
    "@storybook/addon-onboarding": "^10.2.19",
    "@storybook/addon-vitest": "^10.2.19",
    "@storybook/nextjs-vite": "^10.2.19",
    "@tailwindcss/postcss": "^4.2.1",
    "@testing-library/dom": "^10.4.1",
    "@testing-library/jest-dom": "^6.9.1",
    "@testing-library/react": "^16.3.2",
    "@types/better-sqlite3": "^7.6.13",
    "@types/bun": "^1.3.10",
    "@types/node": "^25.5.0",
    "@types/react": "^19.2.14",
    "@types/react-dom": "^19.2.3",
    "@vitejs/plugin-react": "^6.0.1",
    "@vitest/browser": "^4.1.0",
    "@vitest/browser-playwright": "^4.1.0",
    "@vitest/coverage-v8": "^4.1.0",
    "drizzle-kit": "^0.31.9",
    "jsdom": "^29.0.0",
    "lefthook": "^2.1.4",
    "msw": "^2.12.11",
    "playwright": "^1.58.2",
    "postcss": "^8.5.8",
    "semantic-release": "^25.0.3",
    "sharp": "^0.34.5",
    "storybook": "^10.2.19",
    "tailwindcss": "^4.2.1",
    "typescript": "^5.9.3",
    "vite": "^8.0.0",
    "vitest": "^4.1.0"
  }
}
